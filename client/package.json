{
  "name": "mailarchive-client",
  "version": "0.1.0",
  "private": true,
  "description": "IETF Mail Archive — Nuxt 4 frontend (proof of concept)",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "lint": "oxlint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@pinia/nuxt": "0.11.3",
    "nuxt": "4.4.7",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "vue": "3.5.35",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nuxt/test-utils": "4.0.3",
    "@playwright/test": "1.60.0",
    "happy-dom": "20.10.1",
    "oxlint": "1.68.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.3"
  }
}
